{
  "name": "eerzho/opentelemetry-auto-class-symfony",
  "description": "OpenTelemetry auto-instrumentation for PHP class methods (Symfony integration)",
  "type": "symfony-bundle",
  "license": "MIT",
  "keywords": [
    "php",
    "otel",
    "opentelemetry",
    "trace",
    "tracing",
    "instrumentation",
    "auto-instrumentation",
    "bundle",
    "symfony",
    "symfony-bundle"
  ],
  "authors": [
    {
      "name": "Zhanbolat Yerkinbay",
      "email": "eerzho@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "ext-opentelemetry": "*",
    "open-telemetry/api": "^1.0",
    "eerzho/opentelemetry-auto-class": "^0.1",
    "symfony/http-kernel": "^6.0 || ^7.0 || ^8.0",
    "symfony/dependency-injection": "^6.0 || ^7.0 || ^8.0"
  },
  "autoload": {
    "psr-4": {
      "OpenTelemetry\\Contrib\\Instrumentation\\Class\\Symfony\\": "src/"
    }
  },
  "config": {
    "sort-packages": true
  }
}
